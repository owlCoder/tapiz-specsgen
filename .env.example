# ── Baza (MySQL) ──────────────────────────────────────────────────────────────
# Lokalni Docker: mysql://root:root@localhost:3311/tapiz_specsgen
# Aiven: mysql://avnadmin:<pass>@<host>:<port>/tapiz_specsgen
DATABASE_URL="mysql://user:password@localhost:3306/tapiz_specsgen"

# Za Aiven TLS — base64 kodiran ca.pem fajl:
# base64 -w0 ca.pem
# DATABASE_SSL_CA_BASE64=""

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generisati: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true
# Produkcija: pun URL aplikacije (npr. https://specsgen.vercel.app)
# AUTH_URL=

# ── Tapiz LMS SSO ─────────────────────────────────────────────────────────────
# Bez LMS_ promenljivih SSO dugme se ne prikazuje — lokalni dev bez LMS radi.
# Lokalni dev:
#   LMS_UI_URL  = tapiz-reactjs-ui  → http://localhost:5173
#   LMS_API_URL = tapiz-rest-api    → http://localhost:3001/api
# Produkcija:
#   LMS_UI_URL  = https://tapiz.rs
#   LMS_API_URL = https://api.tapiz.rs/api
#
# OAuth klijent mora biti registrovan u tapiz-rest-api/.env OAUTH_CLIENTS:
#   { "client_id": "tapiz-specsgen",
#     "client_secret_sha256": "<echo -n 'secret' | sha256sum>",
#     "redirect_uris": ["https://specsgen.vercel.app/api/auth/callback/tapiz-lms"] }
#
# Generisanje para: openssl rand -hex 32 (plaintext) + echo -n '<secret>' | sha256sum
LMS_UI_URL=""
LMS_API_URL=""
LMS_OAUTH_CLIENT_ID="tapiz-specsgen"
LMS_OAUTH_CLIENT_SECRET=""
