# Baza (MySQL / Aiven)
DATABASE_URL="mysql://user:password@localhost:3306/tapiz_app"
# Za Aiven TLS: base64 kodiran ca.pem fajl
# DATABASE_SSL_CA_BASE64=""

# Auth.js — generisati: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true

# Tapiz LMS SSO (opciono — ako nije postavljeno, SSO dugme se ne prikazuje)
# LMS_UI_URL="https://tapiz.site"
# LMS_API_URL="https://api.tapiz.site/api"
# LMS_OAUTH_CLIENT_ID="tapiz-app-template"
# LMS_OAUTH_CLIENT_SECRET="your-lms-secret"
