{
  "name": "tapiz-specsgen",
  "version": "1.120726.1-w",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node --input-type=commonjs -e \"const fs=require('fs');[['node_modules/.bin/next','../next/dist/bin/next'],['node_modules/.bin/tsc','../typescript/bin/tsc']].forEach(([p,t])=>{try{if(fs.existsSync(p)&&!fs.lstatSync(p).isSymbolicLink()){fs.unlinkSync(p);fs.symlinkSync(t,p);}}catch{}});\"",
    "dev": "next dev -p 3006",
    "build": "next build",
    "start": "next start -p 3006",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
